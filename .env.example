# ========================================
# ARCHIVO DE EJEMPLO DE CONFIGURACION
# ========================================
# Copia este archivo a .env y rellena con tus valores reales
# NUNCA commitear el archivo .env con claves verdaderas

# OpenAI API - Necesario para el analisis de figuras geometricas
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-tu_clave_aqui

# Modelos de OpenAI (opcional - tienen valores por defecto)
MODEL_VISION=gpt-4.1-mini
MODEL_EDUCATIONAL=gpt-4.1-mini
MAX_TOKENS_VISION=400
MAX_TOKENS_EDUCATIONAL=600

# Velocidad de texto a voz (palabras por minuto)
TTS_RATE=150

# Google Gemini API (Opcional)
# Obtener en: https://makersuite.google.com/app/apikey
GEMINI_API=tu_clave_gemini_aqui

# Supabase (Opcional - para persistencia de datos)
# Obtener en: https://supabase.com
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_clave_supabase_aqui
